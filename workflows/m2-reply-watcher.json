        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: \"llama-3.3-70b-versatile\", temperature: 0.3, response_format: { type: \"json_object\" }, messages: $json.messages }) }}",
        "options": {}
