    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const f = $('From').item.json;\nconst lead = (($('Find Lead').item.json.records || [])[0] || {}).fields || {};\nconst sys = 'You help Rehman handle inbound replies to cold outreach. Reply with ONLY JSON '\n  + '{\"summary\":string,\"suggested_reply\":string}. summary: 1-2 sentences on what they want. '\n  + 'suggested_reply: a short friendly reply Rehman can send.';\nconst usr = 'Business: ' + (lead.business_name || '?') + '\\nFrom: ' + f.fromEmail\n  + '\\nSubject: ' + (f.subject || '') + '\\nMessage: ' + (f.snippet || '') + '\\n\\nReturn JSON now.';\nreturn { json: { messages: [{ role: 'system', content: sys }, { role: 'user', content: usr }],\n  business: lead.business_name || f.fromEmail, fromEmail: f.fromEmail, subject: f.subject, snippet: f.snippet } };"
      },
      "id": "rwprompt0000000000000000000000000000",
      "name": "Notify Prompt",
      "type": "n8n-nodes-base.code",
