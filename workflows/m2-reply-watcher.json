      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const c = $json.choices && $json.choices[0] && $json.choices[0].message ? $json.choices[0].message.content : '';\nlet p = { summary: '', suggested_reply: '' };\ntry { const a = c.indexOf('{'), b = c.lastIndexOf('}'); if (a !== -1 && b > a) p = JSON.parse(c.slice(a, b + 1)); } catch (e) {}\nconst np = $('Notify Prompt').item.json;\nconst body = 'New reply from ' + np.business + '\\n\\nFrom: ' + np.fromEmail + '\\nSubject: ' + (np.subject || '')\n  + '\\n\\nSummary: ' + (p.summary || np.snippet || '') + '\\n\\nSuggested reply:\\n' + (p.suggested_reply || '');\nreturn { json: { subject: 'Hot lead replied: ' + np.business, body } };"
      },
